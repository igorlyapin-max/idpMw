{
  "dashboard": {
    "id": null,
    "title": "idmMw Dashboard",
    "tags": ["idmmw"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests/sec",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(idmmw_http_requests_total[1m])",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "HTTP Latency (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(idmmw_http_request_duration_seconds_bucket[1m]))",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "DLQ Size",
        "type": "graph",
        "targets": [
          {
            "expr": "idmmw_dlq_size",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 4,
        "title": "Events Processed",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(idmmw_events_processed_total[1m])",
            "legendFormat": "{{targetSystem}} {{status}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 5,
        "title": "Connector Errors",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(idmmw_connector_errors_total[1m])",
            "legendFormat": "{{connector}} {{operation}}"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
      },
      {
        "id": 6,
        "title": "Processed Last 5 Minutes",
        "type": "graph",
        "targets": [
          {
            "expr": "idmmw_events_processed_last_5m",
            "legendFormat": "{{targetSystem}} {{status}}"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 }
      }
    ]
  }
}
