# idmMw production HA profile for YugabyteDB YSQL.
# Copy this file, replace every REPLACE_* value and keep the real file out of git.

NODE_ENV=production
PORT=3010

DATABASE_PROVIDER=postgresql
DATABASE_FLAVOR=yugabytedb
DATABASE_URL=postgresql://idmmw:REPLACE_WITH_DB_PASSWORD@yugabyte.example.local:5433/idmmw?sslmode=require
LIGHTWEIGHT_MODE=false

IDMMW_PROCESSING_MODE=async
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka-1.example.local:9093,kafka-2.example.local:9093,kafka-3.example.local:9093
KAFKA_CLIENT_ID=idmmw
KAFKA_CONSUMER_GROUP_ID=idmmw-worker-group
KAFKA_TOPIC_EVENTS_IN=idm.events.in
KAFKA_TOPIC_EVENTS_OUT=idm.events.out
KAFKA_TOPIC_DLQ_RETRY=idm.dlq.retry
DLQ_RETRY_LEASE_SECONDS=300

REDIS_ENABLED=false

ADMIN_UI_ENABLED=true
ADMIN_UI_SERVE_STATIC=true
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_MODE=local
ADMIN_AUTH_LOCAL_USERNAME=admin
ADMIN_AUTH_LOCAL_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
ADMIN_AUTH_SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SESSION_SECRET
ADMIN_AUTH_COOKIE_SECURE=true

HTTP_TLS_ENABLED=true
HTTP_TLS_CERT_PATH=/run/secrets/idmmw-http.crt
HTTP_TLS_KEY_PATH=/run/secrets/idmmw-http.key
HTTP_TLS_CA_PATH=/run/secrets/idmmw-client-ca.crt
HTTP_TLS_REQUEST_CLIENT_CERT=false
HTTP_TLS_REJECT_UNAUTHORIZED=true

KAFKA_TLS_ENABLED=true
KAFKA_TLS_CA_PATH=/run/secrets/kafka-ca.crt
KAFKA_TLS_CERT_PATH=/run/secrets/kafka-client.crt
KAFKA_TLS_KEY_PATH=/run/secrets/kafka-client.key
KAFKA_TLS_REJECT_UNAUTHORIZED=true

MOCK_IDM_ENABLED=false

DebugLogging__Enabled=false
DebugLogging__Level=Basic
LOG_SINK=stdout

ENCRYPTION_ENABLED=true
ENCRYPTION_ACTIVE_KEY_ID=key_2026_06
ENCRYPTION_KEYS=key_2026_06
ENCRYPTION_KEY_KEY_2026_06=REPLACE_WITH_BASE64_32_BYTE_KEY
