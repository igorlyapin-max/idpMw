# idmMw production HA profile for CockroachDB.
# Build images with PRISMA_SCHEMA=prisma/schema.cockroach.prisma.

IDMMW_IMAGE=REPLACE_REGISTRY/idmmw:ha-cockroach
IDMMW_ENV_FILE=./profiles/prod-ha-cockroach.env

NODE_ENV=production
PORT=3010

DATABASE_PROVIDER=postgresql
DATABASE_FLAVOR=cockroachdb
DATABASE_URL=postgresql://idmmw:REPLACE_WITH_DB_PASSWORD@cockroach.example.local:26257/idmmw?sslmode=require
LIGHTWEIGHT_MODE=false
PRISMA_SCHEMA=prisma/schema.cockroach.prisma

IDMMW_PROCESSING_MODE=async
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka-1.example.local:9093,kafka-2.example.local:9093,kafka-3.example.local:9093
KAFKA_CLIENT_ID=idmmw
KAFKA_CONSUMER_GROUP_ID=idmmw-worker-group
KAFKA_TOPIC_EVENTS_IN=idm.events.in
KAFKA_TOPIC_EVENTS_OUT=idm.events.out
KAFKA_TOPIC_DLQ_RETRY=idm.dlq.retry
DLQ_RETRY_LEASE_SECONDS=300
INTEGRATION_AUTH_ENABLED=true
INTEGRATION_AUTH_SECRET=secret://idmmw-integration-hmac-secret
INTEGRATION_AUTH_ALLOWED_CLOCK_SKEW_SECONDS=300

REDIS_ENABLED=false

SECRETS_PROVIDER=IndeedPamAapm
SECRETS_INDEEDPAMAAPM_BASEURL=https://pam.example.local
SECRETS_INDEEDPAMAAPM_APPLICATIONTOKEN=REPLACE_WITH_PAM_APP_TOKEN
SECRETS_INDEEDPAMAAPM_TOKEN_TRANSPORT=header
SECRETS_INDEEDPAMAAPM_DEFAULTACCOUNTPATH=REPLACE_WITH_PAM_DEFAULT_ACCOUNT_PATH

ADMIN_UI_ENABLED=true
ADMIN_UI_SERVE_STATIC=true
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_MODE=local
ADMIN_AUTH_LOCAL_USERNAME=admin
ADMIN_AUTH_LOCAL_PASSWORD=secret://idmmw-admin-password
ADMIN_AUTH_SESSION_SECRET=secret://idmmw-admin-session-secret
ADMIN_AUTH_COOKIE_SECURE=true

HTTP_TLS_ENABLED=true
HTTP_TLS_CERT_PATH=/run/secrets/idmmw-http.crt
HTTP_TLS_KEY_PATH=/run/secrets/idmmw-http.key
HTTP_TLS_CA_PATH=/run/secrets/idmmw-client-ca.crt
HTTP_TLS_REQUEST_CLIENT_CERT=false
HTTP_TLS_REJECT_UNAUTHORIZED=true

KAFKA_TLS_ENABLED=true
KAFKA_TLS_CA_PATH=/run/secrets/kafka-ca.crt
KAFKA_TLS_CERT_PATH=/run/secrets/kafka-client.crt
KAFKA_TLS_KEY_PATH=/run/secrets/kafka-client.key
KAFKA_TLS_REJECT_UNAUTHORIZED=true

MOCK_IDM_ENABLED=false
STATIC_CONNECTOR_ALLOWLIST=
TARGET_SYSTEM_REGISTRY_REFRESH_SECONDS=10
METRICS_PUBLIC_ENABLED=false

DebugLogging__Enabled=false
DebugLogging__Level=Basic
LOG_SINK=file
LOG_FILE_PATH=/app/logs/idmmw.log

ENCRYPTION_ENABLED=true
ENCRYPTION_ACTIVE_KEY_ID=key_2026_06
ENCRYPTION_KEYS=key_2026_06
ENCRYPTION_KEY_KEY_2026_06=secret://idmmw-encryption-key-2026-06
