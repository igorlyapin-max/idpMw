# idmMw sqlite-test deployment profile.
# Intended for CI, smoke testing and disposable demos. Do not use for HA/production.

NODE_ENV=development
PORT=3010

DATABASE_PROVIDER=sqlite
DATABASE_URL=file:/app/data/idmmw.db
LIGHTWEIGHT_MODE=true
DATABASE_FLAVOR=postgresql

IDMMW_PROCESSING_MODE=sync
KAFKA_ENABLED=false
REDIS_ENABLED=false
DLQ_RETRY_LEASE_SECONDS=300

ADMIN_UI_ENABLED=false
ADMIN_UI_SERVE_STATIC=false
ADMIN_AUTH_ENABLED=false
MOCK_IDM_ENABLED=false

HTTP_TLS_ENABLED=false

DebugLogging__Enabled=true
DebugLogging__Level=Verbose
LOG_SINK=file
LOG_FILE_PATH=/tmp/idmmw-sqlite-test.log

ENCRYPTION_ENABLED=false
