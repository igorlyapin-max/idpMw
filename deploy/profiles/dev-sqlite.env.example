# idmMw default container deployment profile.
# Copy to deploy/profiles/dev-sqlite.env, replace REPLACE_* values and pass it
# to docker compose with --env-file.

IDMMW_IMAGE=REPLACE_REGISTRY/idmmw:dev-sqlite
IDMMW_ENV_FILE=./profiles/dev-sqlite.env
IDMMW_CONTAINER_NAME=idmmw-dev-sqlite
IDMMW_INIT_CONTAINER_NAME=idmmw-dev-sqlite-db-init
IDMMW_HOST_PORT=3010

NODE_ENV=production
PORT=3010

DATABASE_PROVIDER=sqlite
DATABASE_FLAVOR=postgresql
DATABASE_URL=file:/app/data/idmmw.db
PRISMA_SCHEMA=prisma/schema.sqlite.prisma
LIGHTWEIGHT_MODE=true

IDMMW_PROCESSING_MODE=sync
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=idmmw
KAFKA_CONSUMER_GROUP_ID=idmmw-worker-group
KAFKA_TOPIC_EVENTS_IN=idm.events.in
KAFKA_TOPIC_EVENTS_OUT=idm.events.out
KAFKA_TOPIC_DLQ_RETRY=idm.dlq.retry
DLQ_RETRY_LEASE_SECONDS=300

REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS_ENABLED=false

DB_CONNECTOR_ENABLED=false
DB_CONNECTOR_TLS_ENABLED=false

ADMIN_UI_ENABLED=true
ADMIN_UI_SERVE_STATIC=true
ADMIN_AUTH_ENABLED=false
ADMIN_AUTH_MODE=local
ADMIN_AUTH_LOCAL_USERNAME=admin
ADMIN_AUTH_LOCAL_PASSWORD=change-me
ADMIN_AUTH_SESSION_SECRET=change-me-long-random-session-secret
ADMIN_AUTH_COOKIE_SECURE=false

HTTP_TLS_ENABLED=false
HTTP_TLS_REQUEST_CLIENT_CERT=false
HTTP_TLS_REJECT_UNAUTHORIZED=true

MOCK_IDM_ENABLED=false

SECRETS_PROVIDER=None

DebugLogging__Enabled=false
DebugLogging__Level=Basic
LOG_SINK=stdout
LOG_FILE_PATH=/app/logs/idmmw.log

ENCRYPTION_ENABLED=false
ENCRYPTION_ACTIVE_KEY_ID=key_2026_06
ENCRYPTION_KEYS=key_2026_06
ENCRYPTION_KEY_KEY_2026_06=REPLACE_WITH_BASE64_32_BYTE_KEY
