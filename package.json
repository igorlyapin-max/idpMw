{
  "name": "idm-mw-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev:sqlite": "cross-env DATABASE_PROVIDER=sqlite DATABASE_URL=file:./data/idmmw.db LIGHTWEIGHT_MODE=true nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:sqlite": "bash scripts/test-e2e-sqlite.sh",
    "test:runtime-smoke": "bash scripts/test-runtime-smoke.sh",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:validate": "prisma validate",
    "db:studio": "prisma studio",
    "db:setup:sqlite": "cross-env DATABASE_PROVIDER=sqlite DATABASE_URL=file:./data/idmmw.db LIGHTWEIGHT_MODE=true prisma generate --schema=prisma/schema.sqlite.prisma && cross-env DATABASE_PROVIDER=sqlite DATABASE_URL=file:./data/idmmw.db LIGHTWEIGHT_MODE=true prisma db push --schema=prisma/schema.sqlite.prisma --skip-generate && cross-env DATABASE_PROVIDER=sqlite DATABASE_URL=file:./data/idmmw.db LIGHTWEIGHT_MODE=true prisma generate --schema=prisma/schema.sqlite.prisma",
    "validate": "tsc --noEmit && npm run db:validate && npm run lint"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kafkajs": "^2.2.4",
    "knex": "^3.2.10",
    "mysql2": "^3.22.4",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/client": "^5.22.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.0",
    "@types/supertest": "^7.0.0",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
